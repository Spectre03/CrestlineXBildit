{
  "name": "@bildit-platform/hydrogen",
  "version": "0.1.1",
  "description": "BILDIT CMS integration for Shopify Hydrogen storefronts",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    },
    "./client": {
      "import": "./dist/esm/client.js",
      "require": "./dist/cjs/client.js",
      "types": "./dist/esm/client.d.ts"
    },
    "./server": {
      "import": "./dist/esm/server.js",
      "require": "./dist/cjs/server.js",
      "types": "./dist/esm/server.d.ts"
    }
  },
  "scripts": {
    "build": "rollup -c",
    "build:ci": "rollup -c",
    "dev": "rollup -c -w",
    "lint": "eslint src/**/*.{ts,tsx}",
    "oxlint": "oxlint -c ../../oxlintrc.json",
    "clean": "rimraf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "npm run build",
    "postpublish": "../../scripts/tag-release.sh"
  },
  "keywords": [
    "bildit",
    "cms",
    "hydrogen",
    "shopify",
    "rendering",
    "react"
  ],
  "author": "BILDIT",
  "license": "SEE LICENSE IN LICENSE",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@shopify/hydrogen": ">=2025.1.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-router": ">=7.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^24.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-replace": "^6.0.2",
    "@rollup/plugin-typescript": "^11.0.0",
    "@shopify/hydrogen": "^2025.7.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.14",
    "@types/react": ">=18.0.0",
    "@types/react-dom": ">=18.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "oxlint": "^0.16.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.9.0",
    "rimraf": "^4.0.0",
    "rollup": "^3.0.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-preserve-directives": "^0.4.0",
    "ts-jest": "^29.4.6",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@bildit-platform/react-core": "^0.2.0"
  }
}
